# StallCart - Django Environment
DEBUG=True
SECRET_KEY=django-insecure-dev-key-CHANGE-THIS-BEFORE-PRODUCTION
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# MySQL Credentials
DB_ENGINE=django.db.backends.mysql
DB_NAME=stall_cart_prod
DB_USER=stallcart
DB_PASSWORD=manish@vivek@7080
DB_HOST=127.0.0.1
DB_PORT=3306

# Static & Media
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# Production Settings
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Email
# Use Console for Dev (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=StallCart <noreply@stallcart.in>

# For Production (SMTP/Gmail/SES):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password

# Razorpay
RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY
RAZORPAY_KEY_SECRET=YOUR_TEST_SECRET
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Delivery
DELIVERY_OTP_EXPIRY_MINUTES=15
DEFAULT_DELIVERY_RADIUS_KM=10

# Celery (Optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True


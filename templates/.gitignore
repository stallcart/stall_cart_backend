# ===============================
# StallCart - .gitignore
# Django + MySQL + Docker Project
# ===============================

# SECRETS & ENVIRONMENT (NEVER COMMIT)
.env
.env.local
.env.*.local
*.secret
*.key
*.pem
credentials.json
serviceAccountKey.json

# Python / Django
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# Django Specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
*.pot

# Database (MySQL dump files - keep schema in migrations only)
*.sql
*.dump
*.bak
*.backup

# Docker
.DS_Store
.docker/
docker-compose.override.yml
*.log

#  Node / Frontend (if using npm/yarn later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache
.bower-components/

# 🖥️ IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Testing / Coverage
.coverage
.coverage.*
htmlcov/
.xml
.hypothesis/

# Email / Debug
*.eml
debug.log
error.log

# Temporary / Uploads (keep only placeholders)
media/uploads/*
!media/uploads/.gitkeep
media/products/*
!media/products/.gitkeep
media/branding/*
!media/branding/.gitkeep

# nalytics / Logs
*.log
logs/
*.report

# Build Tools
*.min.js
*.min.css
src/
webpack-stats.json

# Deployment (keep configs, not secrets)
!.env.example
!.dockerignore
!Dockerfile
!docker-compose.yml
!requirements.txt
!requirements/
!Procfile
!runtime.txt

# Keep these (placeholders for structure)
!static/.gitkeep
!templates/.gitkeep
!media/.gitkeep